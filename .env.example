# ===========================================
# Agente Jurídico Breviliere - .env.example
# ===========================================
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# -------------------------------------------
# App Configuration
# -------------------------------------------
APP_NAME=Agente Juridico Breviliere
DEBUG=False
LOG_LEVEL=INFO

# -------------------------------------------
# LLM Configuration
# -------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_LIGHT=gpt-4o-mini

# -------------------------------------------
# Embeddings / Vector Store
# -------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./data/chroma

# -------------------------------------------
# Database Configuration
# -------------------------------------------
DATABASE_URL=postgresql+asyncpg://juridico:juridico_dev@localhost:5432/juridico
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------
# Channels Configuration (WhatsApp, Telegram, Instagram)
# -------------------------------------------
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_API_TOKEN=your-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-id
WHATSAPP_APP_SECRET=your-app-secret

TELEGRAM_BOT_TOKEN=your-telegram-token

INSTAGRAM_ACCESS_TOKEN=your-instagram-token

# Meta API Settings
META_API_VERSION=v18.0

# -------------------------------------------
# Integrations (CRM, Slack, ClickUp, Email)
# -------------------------------------------
CRM_PROVIDER=pipedrive
CRM_API_TOKEN=your-crm-token
CRM_API_URL=https://api.pipedrive.com/v1

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

NOTIFICATION_EMAIL=atendimento@breviliere.com.br

# ClickUp (opcional)
CLICKUP_API_TOKEN=your-clickup-token
CLICKUP_LIST_ID=your-list-id

# -------------------------------------------
# Whisper (Transcrição de Áudio)
# -------------------------------------------
WHISPER_MODEL=whisper-1

# -------------------------------------------
# LGPD / Privacy
# -------------------------------------------
PRIVACY_POLICY_URL=https://breviliere.com.br/privacidade
TERMS_OF_USE_URL=https://breviliere.com.br/termos
DATA_RETENTION_DAYS=1825

# -------------------------------------------
# Session Management
# -------------------------------------------
SESSION_TIMEOUT_HOURS=24

# -------------------------------------------
# PJe / EPROC (Integrações Tribunais)
# -------------------------------------------
# Opcional - para consulta processual
PJE_API_URL=https://pje-api-exemplo.com.br
EPROC_API_URL=https://eproc-api-exemplo.com.br
