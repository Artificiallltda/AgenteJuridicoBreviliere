# === Instagram ===
INSTAGRAM_ACCESS_TOKEN=seu_access_token

# === CRM ===
CRM_PROVIDER=pipedrive
CRM_API_KEY=seu_crm_key

# === Notifications ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
